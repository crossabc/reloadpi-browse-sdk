{
  "name": "@crossabc/reloadpi-browse-sdk",
  "version": "0.1.0",
  "description": "Read-only SDK for browsing ReloadPi vouchers, topups, and eSIMs",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf dist",
    "dev": "tsc -w -p tsconfig.json",
    "prepublishOnly": "npm run clean && npm run build",
    "pack:check": "npm pack --dry-run"
  },
  "keywords": [
    "reloadpi",
    "sdk",
    "topup",
    "voucher",
    "esim"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "rimraf": "^6.1.3",
    "typescript": "^5.9.0"
  }
}